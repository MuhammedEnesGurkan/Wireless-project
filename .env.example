# ── Backend ───────────────────────────────────────────────────────────────────
# Path to the YAML config file (relative or absolute)
CONFIG_PATH=./config.yaml

# Backend server bind settings (can override config.yaml)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── SSH Credentials ────────────────────────────────────────────────────────────
# Paths to SSH private keys for VM1 and VM2
VM1_SSH_KEY_PATH=~/.ssh/vpn_bench_key
VM2_SSH_KEY_PATH=~/.ssh/vpn_bench_key

# Optional: passphrase for SSH key (leave blank if none)
SSH_KEY_PASSPHRASE=

# ── VM Addresses (override config.yaml if set) ────────────────────────────────
VM1_HOST=192.168.56.10
VM1_SSH_PORT=22
VM1_SSH_USER=ubuntu

VM2_HOST=192.168.56.11
VM2_SSH_PORT=22
VM2_SSH_USER=ubuntu

# ── Frontend ───────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/test
